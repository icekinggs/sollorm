# Copie este arquivo para .env e ajuste os valores
# Gere tokens fortes com: openssl rand -hex 32

POSTGRES_PASSWORD=troque_esta_senha_forte_aqui
SECRET_KEY=gere_com_openssl_rand_hex_32
AGENT_MASTER_TOKEN=gere_com_openssl_rand_hex_32

# URL pública do SolloRMM backend usada nos instaladores.
PUBLIC_BACKEND_URL=http://localhost:8000

# Versão do agente SolloRMM publicada em GitHub Releases.
# Para publicar nova versão:
#   1. Crie a release no GitHub com os binários (veja scripts/release.sh)
#   2. Altere AGENT_CURRENT_VERSION abaixo para a nova versão
#   3. docker compose -f deploy/docker-compose.yml up -d backend
#      (apenas restart — NÃO precisa rebuild da imagem Docker)
AGENT_CURRENT_VERSION=v0.6.0

# MeshCentral fica disponível em https://localhost:8443 por padrão.
# Para endpoints fora da máquina local, troque localhost por IP/DNS acessível.
MESHCENTRAL_PUBLIC_URL=https://localhost:8443

# Opcional: cole aqui as URLs dos agentes geradas pelo MeshCentral
# em "Add Agent". Se vazias, o instalador pula o Mesh Agent.
MESHCENTRAL_AGENT_LINUX_URL=
MESHCENTRAL_AGENT_WINDOWS_URL=
